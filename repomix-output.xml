<file path="prisma/schema.prisma">
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PLACED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

type Address {
  street  String
  city    String
  state   String
  zip     String
  country String
  default Boolean @default(false)
}

type Variant {
  type  String // e.g., "Size", "Color"
  value String // e.g., "XXL", "Midnight Black"
  price Int    // Surcharge
  stock Int
}

type OrderTimeline {
  status    OrderStatus
  timestamp DateTime    @default(now())
  note      String?
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  email     String    @unique
  name      String
  password  String
  role      Role      @default(CUSTOMER)
  addresses Address[]
  orders    Order[]
  reviews   Review[]
  cart      Cart?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  price       Float
  images      String[]
  category    String
  stock       Int
  variants    Variant[]
  isFeatured  Boolean  @default(false)
  reviews     Review[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  userId         String          @db.ObjectId
  user           User            @relation(fields: [userId], references: [id])
  items          OrderItem[]
  totalAmount    Float
  shippingAddress Address
  paymentStatus  String          // "PENDING", "COMPLETED", "FAILED"
  orderStatus    OrderStatus     @default(PLACED)
  timeline       OrderTimeline[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

type OrderItem {
  productId String @db.ObjectId
  name      String
  price     Float
  quantity  Int
  image     String
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  comment   String
  userName  String
  createdAt DateTime @default(now())
}

model Cart {
  id      String     @id @default(auto()) @map("_id") @db.ObjectId
  userId  String     @unique @db.ObjectId
  user    User       @relation(fields: [userId], references: [id])
  items   CartItem[]
}

type CartItem {
  productId String @db.ObjectId
  variantId String?
  quantity  Int
}
</file>

<file path="README.md">
## SwiftCart (Amazon-like) - Portfolio Demo

SwiftCart ek full-stack e-commerce demo hai jisme JWT auth, products catalog, cart, checkout -> orders, aur reviews included hain. Admin role se products/orders manage hotay hain.

### Tech Stack
- Backend: `Node.js`, `Express`, `TypeScript`
- Database: `MongoDB` (Prisma ORM)
- Auth: `JWT`, `bcryptjs`
- API: `REST`

### Features (Resume Highlights)
- User `signup/login` + `get profile (me)` via JWT
- Products: listing, search, product details + reviews
- Cart: add/update/remove items
- Checkout: cart -> order (snapshot items) + stock decrement
- Orders: user order history + admin order status update
- Reviews: authenticated users can add product reviews
- Admin: products CRUD + orders listing/status update

### Setup
1. Dependencies install:
   - `npm install`
2. `.env` configure:
   - `DATABASE_URL`, `JWT_SECRET`, `PORT`
3. Prisma DB setup (Mongo):
   - `npx prisma generate`
   - `npx prisma db push`
4. Seed demo data:
   - `npm run seed`
5. Start server:
   - `npm run dev`
6. Frontend:
   - `cd frontend`
   - `npm install`
   - `npm run dev` (Vite runs at `http://localhost:5173`)

Server URL:
- `http://localhost:5000`

Demo Admin (from `npm run seed` defaults):
- Email: `admin@swiftcart.demo`
- Password: `admin1234`

### Sample API Routes
- `POST /api/v1/auth/signup`
- `POST /api/v1/auth/login`
- `GET /api/v1/auth/me`
- `GET /api/v1/products`
- `GET /api/v1/products/:id`
- `GET /api/v1/cart`
- `POST /api/v1/cart/items`
- `PATCH /api/v1/cart/items/:productId`
- `DELETE /api/v1/cart/items/:productId`
- `POST /api/v1/orders/checkout`
- `GET /api/v1/orders`
- `POST /api/v1/reviews?productId=...`
- `GET /api/v1/reviews?productId=...`
- Admin:
  - `POST /api/v1/products` (create)
  - `GET /api/v1/orders/admin` (list)
  - `PATCH /api/v1/orders/admin/:id/status`

### Deployment (Optional)
- Frontend: `frontend/` folder ko Vercel/Netlify par deploy kar sakte ho.
- Backend: `npm run build` aur phir `npm run start` Render/Fly.io/Render par chala sakte ho.
- Env vars:
  - Backend me `DATABASE_URL`, `JWT_SECRET`, `PORT`
  - Frontend me `VITE_API_BASE_URL` (example: `https://your-backend-url.com`)
</file>

