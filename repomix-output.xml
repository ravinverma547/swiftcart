<file path="frontend/src/pages/storefront/OrderDetailsPage.tsx">
import React, { useEffect, useState } from 'react';
import { useParams, Link } from 'react-router-dom';
import api from '../../services/api';
import { CheckCircle, Package, Truck, Calendar } from 'lucide-react';

const OrderDetailsPage: React.FC = () => {
  const { id } = useParams<{ id: string }>();
  const [order, setOrder] = useState<any>(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const fetchOrder = async () => {
      try {
        const { data } = await api.get(`/orders/${id}`);
        setOrder(data.order);
      } catch (error) {
        console.error('Failed to fetch order', error);
      } finally {
        setLoading(false);
      }
    };
    fetchOrder();
  }, [id]);

  if (loading) return <div className="h-screen flex items-center justify-center">Loading Order...</div>;
  if (!order) return <div className="p-20 text-center">Order not found</div>;

  const currentStatusIndex = ['PLACED', 'PROCESSING', 'SHIPPED', 'OUT_FOR_DELIVERY', 'DELIVERED'].indexOf(order.orderStatus);

  return (
    <div className="max-w-4xl mx-auto px-4 py-12 space-y-8">
      <div className="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 text-center space-y-4">
        <div className="flex justify-center"><CheckCircle size={64} className="text-green-500" /></div>
        <h1 className="text-3xl font-bold">Thank you for your order!</h1>
        <p className="text-gray-500">Order <span className="font-bold">#{order.id}</span> has been placed and is being processed.</p>
        <div className="flex justify-center gap-4 pt-4">
           <Link to="/products" className="px-6 py-2 border rounded-full hover:bg-gray-50 transition-colors">Continue Shopping</Link>
           <button onClick={() => window.print()} className="px-6 py-2 bg-gray-100 rounded-full hover:bg-gray-200 transition-colors">Print Invoice</button>
        </div>
      </div>

      {/* Order Tracking Timeline */}
      <div className="bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
        <h2 className="text-xl font-bold mb-8">Order Tracking</h2>
        <div className="relative flex justify-between">
           {['Placed', 'Processing', 'Shipped', 'Out for Delivery', 'Delivered'].map((step, i) => (
             <div key={step} className="flex flex-col items-center z-10 w-24">
                <div className={`w-8 h-8 rounded-full flex items-center justify-center mb-2 ${currentStatusIndex >= i ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-400'}`}>
                   {currentStatusIndex >= i ? <CheckCircle size={16} /> : i + 1}
                </div>
                <span className={`text-[10px] font-bold text-center uppercase tracking-tighter ${currentStatusIndex >= i ? 'text-green-600' : 'text-gray-400'}`}>{step}</span>
             </div>
           ))}
           {/* Line */}
           <div className="absolute top-4 left-12 right-12 h-0.5 bg-gray-200 -z-0"></div>
           <div className={`absolute top-4 left-12 h-0.5 bg-green-500 transition-all duration-1000 -z-0`} style={{ width: `${(currentStatusIndex / 4) * 100}%` }}></div>
        </div>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
         {/* Shipping Info */}
         <div className="bg-white p-6 rounded-2xl shadow-md border border-gray-50">
            <h3 className="font-bold mb-4 flex items-center gap-2 text-gray-400"><Truck size={18} /> Shipping Info</h3>
            <div className="text-sm space-y-1">
               <p className="font-bold">{order.user.name}</p>
               <p>{order.shippingAddress.street}</p>
               <p>{order.shippingAddress.city}, {order.shippingAddress.state} {order.shippingAddress.zip}</p>
               <p>{order.shippingAddress.country}</p>
            </div>
         </div>
         {/* Order Summary */}
         <div className="bg-white p-6 rounded-2xl shadow-md border border-gray-50">
            <h3 className="font-bold mb-4 flex items-center gap-2 text-gray-400"><Package size={18} /> Order Summary</h3>
            <div className="text-sm space-y-2">
               <div className="flex justify-between"><span>Subtotal:</span><span>${order.totalAmount.toFixed(2)}</span></div>
               <div className="flex justify-between"><span>Shipping:</span><span className="text-green-600 font-bold">FREE</span></div>
               <div className="flex justify-between text-lg font-bold pt-2 border-t mt-2"><span>Total:</span><span>${order.totalAmount.toFixed(2)}</span></div>
            </div>
         </div>
      </div>

      {/* Timeline History */}
      <div className="bg-white p-6 rounded-2xl shadow-md border border-gray-50">
        <h3 className="font-bold mb-6 flex items-center gap-2 text-gray-400"><Calendar size={18} /> Status History</h3>
        <div className="space-y-6">
          {order.timeline.map((update: any, i: number) => (
            <div key={i} className="flex gap-4">
               <div className="w-1 bg-green-500 rounded-full"></div>
               <div>
                 <p className="text-sm font-bold text-gray-900">{update.status}</p>
                 <p className="text-xs text-gray-500 italic">{update.note}</p>
                 <p className="text-[10px] text-gray-400">{new Date(update.timestamp).toLocaleString()}</p>
               </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

export default OrderDetailsPage;
</file>

