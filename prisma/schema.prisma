datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PLACED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

type Address {
  street  String
  city    String
  state   String
  zip     String
  country String
  default Boolean @default(false)
}

type Variant {
  type  String // e.g., "Size", "Color"
  value String // e.g., "XXL", "Midnight Black"
  price Int    // Surcharge
  stock Int
}

type OrderTimeline {
  status    OrderStatus
  timestamp DateTime    @default(now())
  note      String?
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  email           String    @unique
  name            String
  password        String
  role            Role      @default(CUSTOMER)
  addresses       Address[]
  orders          Order[]
  reviews         Review[]
  cart            Cart?
  isPrime         Boolean   @default(false)
  totalSpentToday Float     @default(0)
  coupons         Coupon[]
  reports         Report[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Coupon {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  code               String   @unique
  userId             String   @db.ObjectId
  user               User     @relation(fields: [userId], references: [id])
  discountPercentage Float    @default(15)
  isUsed             Boolean  @default(false)
  expiresAt          DateTime
  createdAt          DateTime @default(now())
}

model Report {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])
  userName      String
  type          String   // "DAMAGED", "NOT_ARRIVED", "OTHER"
  message       String
  status        String   @default("PENDING") // "PENDING", "SOLVED"
  adminResponse String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  price       Float
  images      String[]
  category    String
  stock       Int
  variants    Variant[]
  isFeatured  Boolean  @default(false)
  reviews     Review[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  userId         String          @db.ObjectId
  user           User            @relation(fields: [userId], references: [id])
  items          OrderItem[]
  totalAmount    Float
  shippingAddress Address
  paymentStatus  String          // "PENDING", "COMPLETED", "FAILED"
  orderStatus    OrderStatus     @default(PLACED)
  timeline       OrderTimeline[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

type OrderItem {
  productId String @db.ObjectId
  name      String
  price     Float
  quantity  Int
  image     String
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  productId String   @db.ObjectId
  product   Product  @relation(fields: [productId], references: [id])
  rating    Int
  comment   String
  userName  String
  createdAt DateTime @default(now())
}

model Cart {
  id      String     @id @default(auto()) @map("_id") @db.ObjectId
  userId  String     @unique @db.ObjectId
  user    User       @relation(fields: [userId], references: [id])
  items   CartItem[]
}

type CartItem {
  productId String @db.ObjectId
  variantId String?
  quantity  Int
}