                        >
                          {updatingStatus === o.id ? "Updating..." : "Update"}
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              ))}
              {orders.length === 0 && <div className="text-sm text-slate-300">No orders found.</div>}
            </div>
          </div>
        </>
      )}
    </div>
  );
}
